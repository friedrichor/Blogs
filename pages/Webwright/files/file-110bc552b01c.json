  "lines": [
    {
      "number": 1,
      "text": "\"\"\"OpenAI Responses API model backend.\"\"\""
    },
    {
      "number": 2,
      "text": ""
    },
    {
      "number": 3,
      "text": "from __future__ import annotations"
    },
    {
      "number": 4,
      "text": ""
    },
    {
      "number": 5,
      "text": "from pathlib import Path"
    },
    {
      "number": 6,
      "text": "from typing import Any"
    },
    {
      "number": 7,
      "text": ""
    },
    {
      "number": 8,
      "text": "from webwright.models.base import ("
    },
    {
      "number": 9,
      "text": "    BaseModel,"
    },
    {
      "number": 10,
      "text": "    BaseModelConfig,"
    },
    {
      "number": 11,
