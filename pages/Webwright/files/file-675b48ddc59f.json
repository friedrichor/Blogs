    {
      "number": 21,
      "text": "def _serialize_chat_content_part(part: dict[str, Any]) -> dict[str, Any] | None:"
    },
    {
      "number": 22,
      "text": "    part_type = part.get(\"type\")"
    },
    {
      "number": 23,
      "text": "    if part_type in {\"input_text\", \"output_text\"}:"
    },
    {
      "number": 24,
      "text": "        return {\"type\": \"text\", \"text\": str(part.get(\"text\", \"\") or \"\")}"
    },
    {
      "number": 25,
      "text": "    if part_type == \"input_image\":"
    },
    {
      "number": 26,
      "text": "        return {"
    },
    {
      "number": 27,
      "text": "            \"type\": \"image_url\","
    },
    {
      "number": 28,
      "text": "            \"image_url\": {"
    },
    {
      "number": 29,
      "text": "                \"url\": str(part.get(\"image_url\", \"\") or \"\"),"
    },
    {
      "number": 30,
      "text": "                \"detail\": str(part.get(\"detail\", \"high\") or \"high\"),"
    },
    {
      "number": 31,
      "text": "            },"
    },
    {
      "number": 32,
      "text": "        }"
    },
    {
      "number": 33,
      "text": "    return None"
    },
    {
      "number": 34,
      "text": ""
    },
    {
      "number": 35,
      "text": ""
    },
    {
      "number": 36,
      "text": "def _serialize_chat_messages(messages: list[dict[str, Any]]) -> list[dict[str, Any]]:"
    },
    {
      "number": 37,
      "text": "    serialized: list[dict[str, Any]] = []"
    },
    {
      "number": 38,
      "text": "    for message in messages:"
    },
    {
      "number": 39,
      "text": "        role = message[\"role\"]"
    },
    {
      "number": 40,
      "text": "        if role == \"exit\":"
    },
    {
      "number": 41,
      "text": "            continue"
    },
    {
      "number": 42,
      "text": "        mapped_role = \"system\" if role == \"system\" else (\"assistant\" if role == \"assistant\" else \"user\")"
    },
    {
      "number": 43,
      "text": "        content = message.get(\"content\", \"\")"
    },
    {
      "number": 44,
      "text": "        if isinstance(content, str):"
    },
    {
      "number": 45,
      "text": "            serialized.append({\"role\": mapped_role, \"content\": content})"
    },
    {
      "number": 46,
      "text": "            continue"
    },
    {
      "number": 47,
      "text": "        parts = ["
    },
    {
      "number": 48,
      "text": "            serialized_part"
    },
    {
      "number": 49,
      "text": "            for part in content"
    },
    {
      "number": 50,
      "text": "            if isinstance(part, dict)"
    },
    {
      "number": 51,
      "text": "            for serialized_part in [_serialize_chat_content_part(part)]"
    },
    {
      "number": 52,
      "text": "            if serialized_part is not None"
    },
    {
      "number": 53,
      "text": "        ]"
    },
    {
      "number": 54,
      "text": "        if mapped_role == \"assistant\" or all(part.get(\"type\") == \"text\" for part in parts):"
    },
    {
      "number": 55,
      "text": "            serialized.append("
    },
    {
      "number": 56,
      "text": "                {"
    },
    {
      "number": 57,
      "text": "                    \"role\": mapped_role,"
    },
    {
      "number": 58,
      "text": "                    \"content\": \"\\n\".join(str(part.get(\"text\", \"\") or \"\") for part in parts),"
    },
    {
      "number": 59,
      "text": "                }"
    },
    {
      "number": 60,
      "text": "            )"
    },
    {
      "number": 61,
      "text": "        else:"
    },
    {
      "number": 62,
      "text": "            serialized.append({\"role\": mapped_role, \"content\": parts})"
    },
    {
      "number": 63,
      "text": "    return serialized"
    },
    {
      "number": 64,
      "text": ""
    },
    {
      "number": 65,
      "text": ""
    },
    {
      "number": 66,
      "text": "def _metrics_input_from_chat_messages(chat_messages: list[dict[str, Any]]) -> list[dict[str, Any]]:"
    },
    {
      "number": 67,
      "text": "    metrics_input: list[dict[str, Any]] = []"
    },
    {
      "number": 68,
      "text": "    for message in chat_messages:"
    },
    {
      "number": 69,
      "text": "        content = message.get(\"content\", \"\")"
    },
    {
      "number": 70,
      "text": "        if isinstance(content, str):"
    },
    {
      "number": 71,
      "text": "            metrics_input.append({\"content\": [{\"type\": \"input_text\", \"text\": content}]})"
    },
    {
      "number": 72,
      "text": "            continue"
    },
    {
      "number": 73,
      "text": "        parts: list[dict[str, Any]] = []"
    },
    {
      "number": 74,
      "text": "        for part in content:"
    },
    {
      "number": 75,
      "text": "            if not isinstance(part, dict):"
    },
    {
      "number": 76,
      "text": "                continue"
    },
    {
      "number": 77,
      "text": "            if part.get(\"type\") == \"text\":"
    },
    {
      "number": 78,
      "text": "                parts.append({\"type\": \"input_text\", \"text\": str(part.get(\"text\", \"\") or \"\")})"
    },
    {
      "number": 79,
      "text": "            elif part.get(\"type\") == \"image_url\":"
    },
    {
      "number": 80,
      "text": "                parts.append({\"type\": \"input_image\"})"
    },
    {
      "number": 81,
      "text": "        metrics_input.append({\"content\": parts})"
    },
    {
      "number": 82,
      "text": "    return metrics_input"
    },
    {
