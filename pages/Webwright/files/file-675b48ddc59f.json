  "lines": [
    {
      "number": 1,
      "text": "\"\"\"OpenRouter chat completions model backend.\"\"\""
    },
    {
      "number": 2,
      "text": ""
    },
    {
      "number": 3,
      "text": "from __future__ import annotations"
    },
    {
      "number": 4,
      "text": ""
    },
    {
      "number": 5,
      "text": "from typing import Any"
    },
    {
      "number": 6,
      "text": "from urllib.parse import urlparse"
    },
    {
      "number": 7,
      "text": ""
    },
    {
      "number": 8,
      "text": "from webwright.models.base import ("
    },
    {
      "number": 9,
      "text": "    BaseModel,"
    },
    {
      "number": 10,
      "text": "    BaseModelConfig,"
    },
    {
      "number": 11,
      "text": "    OptStr,"
    },
    {
      "number": 12,
      "text": "    _safe_int,"
    },
    {
      "number": 13,
      "text": ")"
    },
    {
      "number": 14,
      "text": ""
    },
    {
      "number": 15,
      "text": "__all__ = ["
    },
    {
      "number": 16,
      "text": "    \"OpenRouterModel\","
    },
    {
      "number": 17,
      "text": "    \"OpenRouterModelConfig\","
    },
    {
      "number": 18,
      "text": "]"
    },
    {
