    },
    {
      "number": 132,
      "text": "class OpenRouterModelConfig(BaseModelConfig):"
    },
    {
      "number": 133,
      "text": "    model_name: OptStr = \"openai/gpt-5.4\""
    },
    {
      "number": 134,
      "text": "    openrouter_api_key: OptStr = \"\""
    },
    {
      "number": 135,
      "text": "    openrouter_endpoint: OptStr = \"https://openrouter.ai/api/v1/chat/completions\""
    },
    {
      "number": 136,
      "text": "    http_referer: OptStr = \"\""
    },
    {
      "number": 137,
      "text": "    app_title: OptStr = \"\""
    },
    {
      "number": 138,
      "text": "    provider_require_parameters: bool = True"
    },
    {
      "number": 139,
      "text": ""
    },
    {
      "number": 140,
      "text": ""
    },
    {
      "number": 141,
      "text": "class OpenRouterModel(BaseModel):"
    },
    {
      "number": 142,
      "text": "    _API_KEY_FIELD = \"openrouter_api_key\""
    },
    {
      "number": 143,
      "text": "    _ENV_VAR = \"OPENROUTER_API_KEY\""
    },
    {
      "number": 144,
      "text": "    _LOG_SOURCE = \"openrouter\""
    },
    {
      "number": 145,
      "text": "    _MAX_RATE_LIMIT_RETRIES = 5"
    },
    {
      "number": 146,
      "text": "    _MAX_TRANSIENT_RETRIES = 5"
    },
    {
      "number": 147,
      "text": "    _DEFAULT_CONFIG_CLASS = OpenRouterModelConfig"
    },
    {
      "number": 148,
      "text": ""
    },
    {
      "number": 149,
      "text": "    def _request_headers(self) -> dict[str, str]:"
    },
    {
      "number": 150,
      "text": "        headers = {"
    },
    {
      "number": 151,
      "text": "            \"Content-Type\": \"application/json\","
    },
    {
      "number": 152,
      "text": "            \"Authorization\": f\"Bearer {self.config.openrouter_api_key}\","
    },
    {
      "number": 153,
      "text": "        }"
    },
    {
      "number": 154,
      "text": "        if _is_openrouter_endpoint(self.config.openrouter_endpoint) and self.config.http_referer:"
    },
    {
      "number": 155,
      "text": "            headers[\"HTTP-Referer\"] = self.config.http_referer"
    },
    {
      "number": 156,
      "text": "        if _is_openrouter_endpoint(self.config.openrouter_endpoint) and self.config.app_title:"
    },
    {
      "number": 157,
      "text": "            headers[\"X-Title\"] = self.config.app_title"
    },
    {
      "number": 158,
      "text": "        return headers"
    },
    {
      "number": 159,
      "text": ""
    },
    {
      "number": 160,
      "text": "    def _post_url(self) -> str:"
    },
    {
      "number": 161,
      "text": "        return self.config.openrouter_endpoint"
    },
    {
      "number": 162,
      "text": ""
    },
    {
      "number": 163,
      "text": "    def _build_payload(self, messages: list[dict[str, Any]]) -> dict[str, Any]:"
    },
    {
      "number": 164,
      "text": "        payload: dict[str, Any] = {"
    },
    {
      "number": 165,
      "text": "            \"model\": self.config.model_name,"
    },
    {
      "number": 166,
      "text": "            \"messages\": _serialize_chat_messages(messages),"
    },
    {
      "number": 167,
      "text": "            \"stream\": False,"
    },
    {
      "number": 168,
      "text": "            \"response_format\": {"
    },
    {
      "number": 169,
      "text": "                \"type\": \"json_schema\","
    },
    {
      "number": 170,
      "text": "                \"json_schema\": {"
    },
    {
      "number": 171,
      "text": "                    \"name\": \"playwright_step\","
    },
    {
      "number": 172,
      "text": "                    \"strict\": True,"
    },
    {
      "number": 173,
      "text": "                    \"schema\": self._response_schema(),"
    },
    {
      "number": 174,
      "text": "                },"
    },
    {
      "number": 175,
      "text": "            },"
    },
    {
      "number": 176,
      "text": "        }"
    },
    {
      "number": 177,
      "text": "        if _is_openai_endpoint(self.config.openrouter_endpoint) and self.config.model_name.startswith(\"gpt-5\"):"
    },
    {
      "number": 178,
      "text": "            payload[\"max_completion_tokens\"] = self.config.max_output_tokens"
    },
    {
      "number": 179,
      "text": "        else:"
    },
    {
      "number": 180,
      "text": "            payload[\"max_tokens\"] = self.config.max_output_tokens"
    },
    {
      "number": 181,
      "text": "        if self.config.provider_require_parameters and _is_openrouter_endpoint(self.config.openrouter_endpoint):"
    },
    {
      "number": 182,
      "text": "            payload[\"provider\"] = {\"require_parameters\": True}"
    },
    {
      "number": 183,
      "text": "        return payload"
    },
    {
      "number": 184,
      "text": ""
    },
    {
      "number": 185,
      "text": "    def _build_text_payload(self, messages: list[dict[str, Any]]) -> dict[str, Any]:"
    },
    {
      "number": 186,
      "text": "        payload: dict[str, Any] = {"
    },
    {
      "number": 187,
      "text": "            \"model\": self.config.model_name,"
    },
    {
      "number": 188,
      "text": "            \"messages\": _serialize_chat_messages(messages),"
    },
    {
      "number": 189,
      "text": "            \"stream\": False,"
    },
    {
      "number": 190,
      "text": "        }"
    },
    {
      "number": 191,
      "text": "        if _is_openai_endpoint(self.config.openrouter_endpoint) and self.config.model_name.startswith(\"gpt-5\"):"
    },
    {
      "number": 192,
      "text": "            payload[\"max_completion_tokens\"] = self.config.max_output_tokens"
    },
    {
      "number": 193,
      "text": "        else:"
    },
    {
      "number": 194,
      "text": "            payload[\"max_tokens\"] = self.config.max_output_tokens"
    },
    {
      "number": 195,
      "text": "        if self.config.provider_require_parameters and _is_openrouter_endpoint(self.config.openrouter_endpoint):"
    },
    {
      "number": 196,
      "text": "            payload[\"provider\"] = {\"require_parameters\": True}"
    },
    {
      "number": 197,
      "text": "        return payload"
    },
    {
      "number": 198,
      "text": ""
    },
    {
      "number": 199,
      "text": "    def _request_metrics_input(self, payload: dict[str, Any]) -> list[dict[str, Any]]:"
    },
    {
      "number": 200,
      "text": "        return _metrics_input_from_chat_messages(payload.get(\"messages\") or [])"
    },
    {
      "number": 201,
      "text": ""
    },
    {
      "number": 202,
      "text": "    def _extract_text(self, payload: dict[str, Any]) -> str:"
    },
    {
      "number": 203,
      "text": "        return _extract_chat_completions_text(payload)"
    },
    {
      "number": 204,
      "text": ""
    },
    {
      "number": 205,
      "text": "    def _usage_metrics_from_payload(self, payload: dict[str, Any]) -> dict[str, int]:"
    },
    {
