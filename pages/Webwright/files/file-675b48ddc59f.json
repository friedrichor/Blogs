      "text": ""
    },
    {
      "number": 84,
      "text": ""
    },
    {
      "number": 85,
      "text": "def _extract_chat_completions_text(payload: dict[str, Any]) -> str:"
    },
    {
      "number": 86,
      "text": "    choices = payload.get(\"choices\")"
    },
    {
      "number": 87,
      "text": "    if not isinstance(choices, list) or not choices:"
    },
    {
      "number": 88,
      "text": "        return \"\""
    },
    {
      "number": 89,
      "text": "    first_choice = choices[0]"
    },
    {
      "number": 90,
      "text": "    if not isinstance(first_choice, dict):"
    },
    {
      "number": 91,
      "text": "        return \"\""
    },
    {
      "number": 92,
      "text": "    message = first_choice.get(\"message\", {})"
    },
    {
      "number": 93,
      "text": "    if not isinstance(message, dict):"
    },
    {
      "number": 94,
      "text": "        return \"\""
    },
    {
      "number": 95,
      "text": "    content = message.get(\"content\", \"\")"
    },
    {
      "number": 96,
      "text": "    if isinstance(content, str):"
    },
    {
      "number": 97,
      "text": "        return content"
    },
    {
      "number": 98,
      "text": "    if isinstance(content, list):"
    },
    {
      "number": 99,
      "text": "        return \"\\n\".join("
    },
    {
      "number": 100,
      "text": "            str(part.get(\"text\", \"\") or \"\")"
    },
    {
      "number": 101,
      "text": "            for part in content"
    },
    {
      "number": 102,
      "text": "            if isinstance(part, dict) and part.get(\"type\") == \"text\""
    },
    {
      "number": 103,
      "text": "        )"
    },
    {
      "number": 104,
      "text": "    return \"\""
    },
    {
      "number": 105,
      "text": ""
    },
    {
      "number": 106,
      "text": ""
    },
    {
      "number": 107,
      "text": "def _usage_metrics_from_chat_completions(payload: dict[str, Any]) -> dict[str, int]:"
    },
    {
      "number": 108,
      "text": "    usage = payload.get(\"usage\")"
    },
    {
      "number": 109,
      "text": "    if not isinstance(usage, dict):"
    },
    {
      "number": 110,
      "text": "        usage = {}"
    },
    {
      "number": 111,
      "text": "    return {"
    },
    {
      "number": 112,
      "text": "        \"input_tokens\": _safe_int(usage.get(\"prompt_tokens\")),"
    },
    {
      "number": 113,
      "text": "        \"output_tokens\": _safe_int(usage.get(\"completion_tokens\")),"
    },
    {
      "number": 114,
      "text": "        \"total_tokens\": _safe_int(usage.get(\"total_tokens\")),"
    },
    {
      "number": 115,
      "text": "        \"cached_input_tokens\": 0,"
    },
    {
      "number": 116,
      "text": "        \"reasoning_output_tokens\": 0,"
    },
    {
      "number": 117,
      "text": "    }"
    },
    {
      "number": 118,
      "text": ""
    },
    {
      "number": 119,
      "text": ""
    },
    {
      "number": 120,
      "text": "def _endpoint_host(endpoint: str) -> str:"
    },
    {
      "number": 121,
      "text": "    return (urlparse(endpoint).hostname or \"\").lower()"
    },
    {
      "number": 122,
      "text": ""
    },
    {
      "number": 123,
      "text": ""
    },
    {
      "number": 124,
      "text": "def _is_openai_endpoint(endpoint: str) -> bool:"
    },
    {
      "number": 125,
      "text": "    return _endpoint_host(endpoint) == \"api.openai.com\""
    },
    {
      "number": 126,
      "text": ""
    },
    {
      "number": 127,
      "text": ""
    },
    {
      "number": 128,
      "text": "def _is_openrouter_endpoint(endpoint: str) -> bool:"
    },
    {
      "number": 129,
      "text": "    return _endpoint_host(endpoint).endswith(\"openrouter.ai\")"
    },
