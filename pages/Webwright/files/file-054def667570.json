      "text": ""
    },
    {
      "number": 121,
      "text": ""
    },
    {
      "number": 122,
      "text": "def _find_chromium_executable(explicit_path: str = \"\") -> str:"
    },
    {
      "number": 123,
      "text": "    candidates = []"
    },
    {
      "number": 124,
      "text": "    if explicit_path:"
    },
    {
      "number": 125,
      "text": "        candidates.append(explicit_path)"
    },
    {
      "number": 126,
      "text": "    candidates.extend("
    },
    {
      "number": 127,
      "text": "        value"
    },
    {
      "number": 128,
      "text": "        for value in (os.environ.get(\"LOCAL_BROWSER_EXECUTABLE\"), os.environ.get(\"BROWSER_EXECUTABLE\"))"
    },
    {
      "number": 129,
      "text": "        if value"
    },
    {
      "number": 130,
      "text": "    )"
    },
    {
      "number": 131,
      "text": "    candidates.extend(_CHROMIUM_EXECUTABLE_CANDIDATES)"
    },
    {
      "number": 132,
      "text": ""
    },
    {
      "number": 133,
      "text": "    for candidate in candidates:"
    },
    {
      "number": 134,
      "text": "        expanded = os.path.expanduser(candidate)"
    },
    {
      "number": 135,
      "text": "        if Path(expanded).exists():"
    },
    {
      "number": 136,
      "text": "            return expanded"
    },
    {
      "number": 137,
      "text": "        resolved = shutil.which(expanded)"
    },
    {
      "number": 138,
      "text": "        if resolved:"
    },
    {
      "number": 139,
      "text": "            return resolved"
    },
    {
      "number": 140,
      "text": "    raise FileNotFoundError("
    },
    {
      "number": 141,
      "text": "        \"Could not find Chrome/Chromium. Set local_cdp_executable or LOCAL_BROWSER_EXECUTABLE.\""
    },
    {
      "number": 142,
      "text": "    )"
    },
    {
      "number": 143,
      "text": ""
    },
    {
      "number": 144,
      "text": ""
    },
    {
      "number": 145,
      "text": "def _macos_open_app_name(executable: str) -> str:"
    },
    {
      "number": 146,
      "text": "    if sys.platform != \"darwin\":"
    },
    {
      "number": 147,
      "text": "        return \"\""
    },
    {
      "number": 148,
