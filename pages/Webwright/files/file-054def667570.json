      "number": 518,
      "text": "            }"
    },
    {
      "number": 519,
      "text": "        }"
    },
    {
      "number": 520,
      "text": ""
    },
    {
      "number": 521,
      "text": "    def close(self) -> None:"
    },
    {
      "number": 522,
      "text": "        if self.config.prompt_before_close:"
    },
    {
      "number": 523,
      "text": "            input(\"Press Enter to close the browser...\")"
    },
    {
      "number": 524,
      "text": "        if self.config.keep_open_on_exit:"
    },
    {
      "number": 525,
      "text": "            return"
    },
    {
      "number": 526,
      "text": "        try:"
    },
    {
      "number": 527,
      "text": "            self._run(self._close_async())"
    },
    {
      "number": 528,
      "text": "        finally:"
    },
    {
      "number": 529,
      "text": "            if self._loop is not None and not self._loop.is_closed():"
    },
    {
      "number": 530,
      "text": "                self._loop.close()"
