    {
      "number": 531,
      "text": "            self._loop = None"
    },
    {
      "number": 532,
      "text": ""
    },
    {
      "number": 533,
      "text": "    async def _close_async(self) -> None:"
    },
    {
      "number": 534,
      "text": ""
    },
    {
      "number": 535,
      "text": "        context = self._context"
    },
    {
      "number": 536,
      "text": "        browser = self._browser"
    },
    {
      "number": 537,
      "text": "        page = self._local_cdp_page"
    },
    {
      "number": 538,
      "text": "        playwright = self._playwright"
    },
    {
      "number": 539,
      "text": "        connected_over_cdp = self._connected_over_cdp"
    },
    {
      "number": 540,
      "text": "        local_cdp_process = self._local_cdp_process"
    },
    {
      "number": 541,
      "text": "        self._page = None"
    },
    {
      "number": 542,
      "text": "        self._local_cdp_page = None"
    },
    {
      "number": 543,
      "text": "        self._context = None"
    },
    {
      "number": 544,
      "text": "        self._browser = None"
    },
    {
      "number": 545,
      "text": "        self._playwright = None"
    },
    {
      "number": 546,
      "text": "        self._connected_over_cdp = False"
    },
    {
      "number": 547,
      "text": "        self._local_cdp_process = None"
    },
    {
      "number": 548,
      "text": ""
    },
    {
      "number": 549,
      "text": "        try:"
    },
    {
      "number": 550,
      "text": "            if connected_over_cdp:"
    },
    {
      "number": 551,
      "text": "                if page is not None and self.config.local_cdp_close_page_on_exit:"
    },
    {
      "number": 552,
      "text": "                    try:"
    },
    {
      "number": 553,
      "text": "                        await page.close()"
    },
    {
      "number": 554,
      "text": "                    except Exception:"
    },
    {
      "number": 555,
      "text": "                        pass"
    },
    {
      "number": 556,
      "text": "                if ("
    },
    {
      "number": 557,
      "text": "                    local_cdp_process is not None"
    },
    {
      "number": 558,
      "text": "                    and self.config.local_cdp_close_started_browser_on_exit"
    },
    {
      "number": 559,
      "text": "                ):"
    },
    {
      "number": 560,
      "text": "                    local_cdp_process.terminate()"
    },
    {
      "number": 561,
      "text": "            elif context is not None:"
    },
    {
      "number": 562,
      "text": "                await context.close()"
    },
    {
      "number": 563,
      "text": "            elif browser is not None:"
    },
    {
      "number": 564,
      "text": "                await browser.close()"
    },
    {
      "number": 565,
      "text": "        finally:"
    },
    {
      "number": 566,
      "text": "            if playwright is not None:"
    },
    {
      "number": 567,
      "text": "                await playwright.stop()"
    }
