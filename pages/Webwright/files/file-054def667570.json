    {
      "number": 202,
      "text": "        if fields_set is None:"
    },
    {
      "number": 203,
      "text": "            fields_set = getattr(self.config, \"__fields_set__\", set())"
    },
    {
      "number": 204,
      "text": "        self._config_fields_set = set(fields_set)"
    },
    {
      "number": 205,
