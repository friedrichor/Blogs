      "number": 41,
      "text": ""
    },
    {
      "number": 42,
      "text": "def _local_cdp_origin(cdp_url: str) -> str:"
    },
    {
      "number": 43,
      "text": "    parsed = urlparse(cdp_url or _DEFAULT_LOCAL_CDP_URL)"
    },
    {
      "number": 44,
      "text": "    scheme = parsed.scheme or \"http\""
    },
    {
      "number": 45,
      "text": "    netloc = parsed.netloc or parsed.path"
    },
    {
      "number": 46,
      "text": "    if not netloc:"
    },
    {
      "number": 47,
      "text": "        netloc = urlparse(_DEFAULT_LOCAL_CDP_URL).netloc"
    },
    {
      "number": 48,
      "text": "    return f\"{scheme}://{netloc}\""
    },
    {
      "number": 49,
      "text": ""
    },
    {
      "number": 50,
      "text": ""
    },
    {
      "number": 51,
      "text": "def _local_cdp_port(cdp_url: str) -> int:"
    },
    {
      "number": 52,
      "text": "    parsed = urlparse(cdp_url or _DEFAULT_LOCAL_CDP_URL)"
    },
    {
      "number": 53,
      "text": "    if parsed.port is not None:"
    },
    {
      "number": 54,
      "text": "        return parsed.port"
    },
    {
      "number": 55,
      "text": "    return 443 if parsed.scheme == \"https\" else 80"
    },
    {
      "number": 56,
      "text": ""
    },
    {
      "number": 57,
      "text": ""
    },
    {
      "number": 58,
      "text": "def _is_local_cdp_available(cdp_url: str, *, timeout_seconds: float = 0.5) -> bool:"
    },
    {
      "number": 59,
      "text": "    try:"
    },
    {
      "number": 60,
      "text": "        with _urlopen_local_cdp("
    },
    {
      "number": 61,
      "text": "            f\"{_local_cdp_origin(cdp_url).rstrip('/')}/json/version\","
    },
    {
      "number": 62,
      "text": "            timeout=timeout_seconds,"
    },
    {
      "number": 63,
      "text": "        ) as response:"
    },
    {
      "number": 64,
      "text": "            return 200 <= response.status < 300"
    },
    {
      "number": 65,
      "text": "    except Exception:"
    },
    {
      "number": 66,
      "text": "        return False"
    },
    {
      "number": 67,
      "text": ""
    },
    {
      "number": 68,
      "text": ""
    },
    {
      "number": 69,
      "text": "def _local_cdp_json_url(cdp_url: str, path: str) -> str:"
    },
    {
      "number": 70,
      "text": "    return f\"{_local_cdp_origin(cdp_url).rstrip('/')}{path}\""
    },
    {
      "number": 71,
      "text": ""
    },
    {
      "number": 72,
      "text": ""
    },
    {
      "number": 73,
      "text": "def _local_cdp_page_targets(cdp_url: str, *, timeout_seconds: float = 0.5) -> list[dict[str, Any]]:"
    },
    {
      "number": 74,
      "text": "    try:"
    },
    {
      "number": 75,
      "text": "        with _urlopen_local_cdp("
    },
    {
      "number": 76,
      "text": "            _local_cdp_json_url(cdp_url, \"/json/list\"),"
    },
    {
      "number": 77,
      "text": "            timeout=timeout_seconds,"
    },
    {
      "number": 78,
      "text": "        ) as response:"
    },
    {
      "number": 79,
      "text": "            if not 200 <= response.status < 300:"
    },
    {
      "number": 80,
      "text": "                return []"
    },
    {
      "number": 81,
      "text": "            payload = json.loads(response.read().decode(\"utf-8\"))"
    },
    {
      "number": 82,
      "text": "    except Exception:"
    },
    {
      "number": 83,
      "text": "        return []"
    },
    {
      "number": 84,
      "text": "    if not isinstance(payload, list):"
    },
    {
      "number": 85,
      "text": "        return []"
    },
    {
      "number": 86,
      "text": "    return ["
    },
    {
      "number": 87,
      "text": "        target"
    },
    {
      "number": 88,
      "text": "        for target in payload"
    },
    {
      "number": 89,
      "text": "        if isinstance(target, dict) and target.get(\"type\") == \"page\""
    },
    {
      "number": 90,
      "text": "    ]"
    },
    {
      "number": 91,
      "text": ""
    },
    {
      "number": 92,
      "text": ""
    },
    {
      "number": 93,
      "text": "def _ensure_local_cdp_page_target(cdp_url: str, *, timeout_seconds: float = 1.0) -> None:"
    },
    {
      "number": 94,
      "text": "    if _local_cdp_page_targets(cdp_url, timeout_seconds=timeout_seconds):"
    },
    {
      "number": 95,
      "text": "        return"
    },
    {
      "number": 96,
      "text": ""
    },
    {
      "number": 97,
      "text": "    target_url = f\"{_local_cdp_json_url(cdp_url, '/json/new')}?{quote('about:blank', safe='')}\""
    },
    {
      "number": 98,
      "text": "    request = Request(target_url, method=\"PUT\")"
    },
    {
      "number": 99,
      "text": "    with _urlopen_local_cdp(request, timeout=timeout_seconds) as response:"
    },
    {
      "number": 100,
      "text": "        if not 200 <= response.status < 300:"
    },
    {
      "number": 101,
      "text": "            raise RuntimeError(f\"Could not create a local CDP page target: {cdp_url}\")"
