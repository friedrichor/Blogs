      "number": 113,
      "text": ""
    },
    {
      "number": 114,
      "text": ""
    },
    {
      "number": 115,
      "text": "def _resolve_user_data_dir(configured_dir: Path, *, explicit: bool) -> Path:"
    },
    {
      "number": 116,
      "text": "    if explicit:"
    },
    {
      "number": 117,
      "text": "        return configured_dir"
    },
    {
      "number": 118,
      "text": "    env_dir = os.environ.get(\"LOCAL_BROWSER_USER_DATA_DIR\") or os.environ.get(\"BROWSER_USER_DATA_DIR\")"
